# Copy to .env and fill in real values for local development.
# See src/config/env.js for defaults and how each var is used.

PORT=3000

DUFFEL_TOKEN=
DUFFEL_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
SUPPORT_EMAIL=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

SENTRY_DSN=
NODE_ENV=development

ANTHROPIC_API_KEY=

REDIS_URL=

ALLOWED_ORIGINS=

ADMIN_TOKEN=

# Optional — flywise-app's Render "Deploy Hook" URL. When set, publishing/
# editing/deleting a city, country, airport, route, or blog post triggers a
# frontend rebuild so the SSG build picks up the change immediately.
RENDER_DEPLOY_HOOK_URL=

# Optional — the Next.js frontend's base URL and a shared secret (must
# match its REVALIDATE_SECRET env var), used to call its /api/revalidate
# route on-demand for the specific route page/blog post that changed
# (Phase 2 of the Next.js migration). Additive to RENDER_DEPLOY_HOOK_URL
# above, not a replacement.
NEXTJS_REVALIDATE_URL=
NEXTJS_REVALIDATE_SECRET=
